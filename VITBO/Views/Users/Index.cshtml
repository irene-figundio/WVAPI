@model VITBO.Models.PagedResult<VITBO.Models.UserDto>

@{
    ViewData["Title"] = "Users Management";
    var currentFilter = ViewData["CurrentFilter"]?.ToString();
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-primary"><i class="bi bi-people me-2"></i> Users Directory</h5>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-1"></i> Create New User</a>
        <form method="get" class="d-flex" asp-action="Index">
            <input type="text" name="query" class="form-control form-control-sm me-2" placeholder="Search users..." value="@currentFilter" />
            <button type="submit" class="btn btn-primary btn-sm">Search</button>
            @if (!string.IsNullOrEmpty(currentFilter))
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-2">Clear</a>
            }
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="ps-4">ID</th>
                        <th scope="col">Username</th>
                        <th scope="col">Email</th>
                        <th scope="col">Role</th>
                        <th scope="col">Status</th>
                        <th scope="col">Created On</th>
                        <th scope="col">Last Login</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        @foreach (var user in Model.Items)
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-bold">#@user.Id</td>
                                <td>@user.Username</td>
                                <td><a href="mailto:@user.Email" class="text-decoration-none">@user.Email</a></td>
                                <td>
                                    @if (user.SuperAdmin)
                                    {
                                        <span class="badge bg-danger">Super Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">User</span>
                                    }
                                </td>
                                <td>
                                    @if (user.StatusId == 1)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Inactive</span>
                                    }
                                </td>
                                <td class="text-muted small">@user.CreationTime.ToString("g")</td>
                                <td class="text-muted small">
                                    @(user.LastLoginTime.HasValue ? user.LastLoginTime.Value.ToString("g") : "Never")
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">No users found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.Total > Model.PageSize)
    {
        <div class="card-footer bg-white border-top">
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-query="@currentFilter">Previous</a>
                    </li>
                    <li class="page-item disabled"><span class="page-link">Page @Model.Page</span></li>
                    <li class="page-item @(Model.Page * Model.PageSize >= Model.Total ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-query="@currentFilter">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
