@model VITBO.Models.CreateUserRequest

@{
    ViewData["Title"] = "Create New User";
}

<div class="card border-0 shadow-sm border-start border-primary border-4">
    <div class="card-header bg-white border-bottom py-3">
        <h5 class="mb-0 text-primary"><i class="bi bi-person-plus me-2"></i> Create New User</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="Username" class="form-control" placeholder="Username" />
                    <label asp-for="Username" class="ms-2">Username</label>
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                    <label asp-for="Email" class="ms-2">Email Address</label>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="Password" class="form-control" placeholder="Password" />
                    <label asp-for="Password" class="ms-2">Password</label>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <select asp-for="StatusId" class="form-select">
                        <option value="1">Active</option>
                        <option value="0">Inactive</option>
                    </select>
                    <label asp-for="StatusId" class="ms-2">Status</label>
                    <span asp-validation-for="StatusId" class="text-danger"></span>
                </div>

                <div class="col-12 mb-3">
                    <div class="form-check form-switch">
                        <input asp-for="SuperAdmin" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="SuperAdmin" class="form-check-label text-muted fw-bold">Grant Super Admin Privileges</label>
                    </div>
                </div>

                <div class="col-12 mt-4 d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-5"><i class="bi bi-save me-2"></i> Save User</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
