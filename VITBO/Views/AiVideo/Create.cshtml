@model VITBO.Models.CreateVideoRequest

@{
    ViewData["Title"] = "Add AI Video";
}

<div class="card border-0 shadow-sm border-start border-success border-4">
    <div class="card-header bg-white border-bottom py-3">
        <h5 class="mb-0 text-success"><i class="bi bi-camera-video me-2"></i> Add New AI Video</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-8 form-floating mb-3">
                    <input asp-for="Title" class="form-control" placeholder="Video Title" />
                    <label asp-for="Title" class="ms-2">Video Title</label>
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-4 form-floating mb-3">
                    <input asp-for="ID_Session" type="number" class="form-control" placeholder="1" />
                    <label asp-for="ID_Session" class="ms-2">Session ID</label>
                    <span asp-validation-for="ID_Session" class="text-danger"></span>
                </div>

                <div class="col-12 form-floating mb-3">
                    <input asp-for="Url_Video" class="form-control" placeholder="example.mp4" />
                    <label asp-for="Url_Video" class="ms-2">Video File Name / URL</label>
                    <span asp-validation-for="Url_Video" class="text-danger"></span>
                    <small class="text-muted d-block mt-1">Ensure the video is uploaded to the respective storage directory.</small>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="Play_Priority" type="number" class="form-control" placeholder="0" />
                    <label asp-for="Play_Priority" class="ms-2">Playback Priority</label>
                    <span asp-validation-for="Play_Priority" class="text-danger"></span>
                </div>

                <div class="col-12 mb-3">
                    <div class="form-check form-switch mt-2">
                        <input asp-for="IsLandscape" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsLandscape" class="form-check-label text-muted fw-bold">Orientation: Landscape Mode</label>
                    </div>
                </div>

                <div class="col-12 mt-4 d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-success px-5"><i class="bi bi-save me-2"></i> Save Video</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
