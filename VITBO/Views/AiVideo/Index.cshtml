@model VITBO.Models.PagedResult<VITBO.Models.VideoListItemDto>

@{
    ViewData["Title"] = "AI Video Management";
    var currentFilter = ViewData["CurrentFilter"]?.ToString();
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-success"><i class="bi bi-camera-video me-2"></i> AI Videos Repository</h5>
        <a asp-action="Create" class="btn btn-success btn-sm"><i class="bi bi-plus-circle me-1"></i> Add AI Video</a>
        <form method="get" class="d-flex" asp-action="Index">
            <input type="text" name="q" class="form-control form-control-sm me-2" placeholder="Search videos..." value="@currentFilter" />
            <button type="submit" class="btn btn-success btn-sm">Search</button>
            @if (!string.IsNullOrEmpty(currentFilter))
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-2">Clear</a>
            }
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="ps-4">ID</th>
                        <th scope="col">Thumbnail / URL</th>
                        <th scope="col">Title</th>
                        <th scope="col">Format</th>
                        <th scope="col">Priority</th>
                        <th scope="col">Created On</th>
                        <th scope="col">Session ID</th>
                        <th scope="col" class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        @foreach (var video in Model.Items)
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-bold">#@video.Id</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(video.PublicUrl))
                                    {
                                        <!-- For a real project, consider generating video thumbnails, but link works for now -->
                                        <a href="@video.PublicUrl" target="_blank" class="btn btn-sm btn-outline-info" title="Preview Video">
                                            <i class="bi bi-play-circle me-1"></i> View
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">No URL</span>
                                    }
                                </td>
                                <td>
                                    <span class="fw-semibold text-dark d-block">@(string.IsNullOrEmpty(video.Title) ? "Untitled Video" : video.Title)</span>
                                </td>
                                <td>
                                    @if (video.IsLandscape)
                                    {
                                        <span class="badge bg-primary"><i class="bi bi-phone-landscape me-1"></i>Landscape</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-phone me-1"></i>Portrait</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-dark">@(video.Play_Priority.HasValue ? video.Play_Priority.ToString() : "N/A")</span>
                                </td>
                                <td class="text-muted small">@video.DataCreation.ToString("g")</td>
                                <td>
                                    <span class="text-muted fw-bold">@video.ID_Session</span>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@video.Id" class="btn btn-sm btn-outline-primary" title="Edit Video">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <form asp-action="Delete" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this video?');">
                                        <input type="hidden" name="id" value="@video.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Video">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">No AI videos found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.Total > Model.PageSize)
    {
        <div class="card-footer bg-white border-top">
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-q="@currentFilter">Previous</a>
                    </li>
                    <li class="page-item disabled"><span class="page-link">Page @Model.Page</span></li>
                    <li class="page-item @(Model.Page * Model.PageSize >= Model.Total ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-q="@currentFilter">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
