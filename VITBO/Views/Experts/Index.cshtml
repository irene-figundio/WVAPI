@model List<VITBO.Models.ExpertDto>

@{
    ViewData["Title"] = "Experts Management";
    int currentLangId = ViewData["CurrentLangId"] != null ? (int)ViewData["CurrentLangId"]! : 1;
}

<div class="card border-0 shadow-sm border-start border-primary border-4">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-primary"><i class="bi bi-person-badge me-2"></i> Experts Directory</h5>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-1"></i> New Expert</a>

        <form method="get" asp-action="Index" class="d-flex align-items-center">
            <label class="me-2 text-muted small fw-bold">Language ID:</label>
            <select name="langId" class="form-select form-select-sm" onchange="this.form.submit()">
                <!option value="1" @(currentLangId == 1 ? "selected" : "")>Italian (1)</!option>
                <!option value="2" @(currentLangId == 2 ? "selected" : "")>English (2)</!option>
            </select>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="ps-4" style="width: 5%">ID</th>
                        <th scope="col" style="width: 30%">Name</th>
                        <th scope="col" style="width: 30%">Email</th>
                        <th scope="col" class="text-end pe-4" style="width: 35%">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var expert in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-bold">#@expert.Id</td>
                                <td><span class="d-block fw-bold text-dark">@expert.Name</span></td>
                                <td>@expert.Email</td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@expert.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
                                    <form asp-action="Delete" asp-route-id="@expert.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this expert?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">No experts found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
