@model VITBO.Models.ExpertDto

@{
    ViewData["Title"] = "Create Expert";
}

<div class="container-fluid px-4 py-4">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h2 class="h3 mb-0 text-gray-800">
                <i class="bi bi-person-plus text-primary me-2"></i> Create New Expert
            </h2>
            <p class="text-muted small mt-1 mb-0">Add a new expert profile to the system.</p>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Expert Details</h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="mb-3">
                            <label asp-for="LangID" class="form-label fw-bold small text-muted">Language</label>
                            <select asp-for="LangID" class="form-select">
                                <option value="1">English (1)</option>
                                <option value="2">Italiano (2)</option>
                            </select>
                            <span asp-validation-for="LangID" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold small text-muted">Name</label>
                            <input asp-for="Name" class="form-control" placeholder="Enter expert's full name" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold small text-muted">Email</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="expert@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhotoUrl" class="form-label fw-bold small text-muted">Photo URL</label>
                            <input asp-for="PhotoUrl" class="form-control" placeholder="https://..." />
                            <span asp-validation-for="PhotoUrl" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Bio" class="form-label fw-bold small text-muted">Biography</label>
                            <textarea asp-for="Bio" class="form-control" rows="5" placeholder="Enter expert biography..."></textarea>
                            <span asp-validation-for="Bio" class="text-danger small"></span>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-save me-1"></i> Save Expert
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
