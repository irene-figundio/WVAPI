@model VITBO.Models.ExpertDto

@{
    ViewData["Title"] = "Edit Expert";
}

<div class="container-fluid px-4 py-4">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h2 class="h3 mb-0 text-gray-800">
                <i class="bi bi-pencil-square text-primary me-2"></i> Edit Expert
            </h2>
            <p class="text-muted small mt-1 mb-0">Modify details for @Model.Name</p>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Expert Profile Editor</h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="LangID" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold small text-muted">Name</label>
                            <input asp-for="Name" class="form-control" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold small text-muted">Email</label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhotoUrl" class="form-label fw-bold small text-muted">Photo URL</label>
                            <div class="d-flex align-items-center gap-3">
                                @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                                {
                                    <img src="@Model.PhotoUrl" alt="@Model.Name" style="height: 60px; width: 60px; object-fit: cover;" class="rounded-circle shadow-sm" />
                                }
                                <div class="flex-grow-1">
                                    <input asp-for="PhotoUrl" class="form-control" />
                                    <span asp-validation-for="PhotoUrl" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Bio" class="form-label fw-bold small text-muted">Biography</label>
                            <textarea asp-for="Bio" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Bio" class="text-danger small"></span>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-save me-1"></i> Update Expert
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
