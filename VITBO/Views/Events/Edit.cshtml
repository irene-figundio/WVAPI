@model VITBO.Services.UpdateEventRequest

@{
    ViewData["Title"] = "Edit Event";
}

<div class="card border-0 shadow-sm border-start border-warning border-4">
    <div class="card-header bg-white border-bottom py-3">
        <h5 class="mb-0 text-warning"><i class="bi bi-pencil-square me-2"></i> Edit Event #@Model.id</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-8 form-floating mb-3">
                    <input asp-for="Title" class="form-control" placeholder="Title" />
                    <label asp-for="Title" class="ms-2">Event Title</label>
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-4 form-floating mb-3">
                    <select asp-for="LangID" class="form-select" id="langSelect">
                        <option value="1">English (1)</option>
                        <option value="2">Italiano (2)</option>
                    </select>
                    <label asp-for="LangID" class="ms-2">Language</label>
                    <span asp-validation-for="LangID" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="HeroImage" class="form-control" placeholder="Hero Image URL" />
                    <label asp-for="HeroImage" class="ms-2">Hero Image URL</label>
                    <span asp-validation-for="HeroImage" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="CoverImage" class="form-control" placeholder="Cover Image URL" />
                    <label asp-for="CoverImage" class="ms-2">Cover Image URL</label>
                    <span asp-validation-for="CoverImage" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="EventDate" type="date" class="form-control" value="@Model.EventDate.ToString("yyyy-MM-dd")" />
                    <label asp-for="EventDate" class="ms-2">Event Date</label>
                    <span asp-validation-for="EventDate" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" />
                    <label asp-for="Price" class="ms-2">Ticket Price (€)</label>
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="col-12 form-floating mb-3">
                    <input asp-for="Location" class="form-control" placeholder="Location" />
                    <label asp-for="Location" class="ms-2">Location / Venue</label>
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="col-12 form-floating mb-3">
                    <textarea asp-for="Description" class="form-control" placeholder="Description" style="height: 120px">@Model.Description</textarea>
                    <label asp-for="Description" class="ms-2">Event Description</label>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="form-check form-switch mt-2">
                        <input asp-for="IsOnline" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsOnline" class="form-check-label text-muted fw-bold">Online Event</label>
                    </div>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <select asp-for="CategoryId" class="form-select" id="categorySelect">
                        <option value="">-- Select Category --</option>
                    </select>
                    <label asp-for="CategoryId" class="ms-2">Category (Optional)</label>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="col-12 mt-4 d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-warning text-dark px-5 fw-bold"><i class="bi bi-save me-2"></i> Update Event</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            function loadCategories(langId, selectedCategoryId) {
                $.getJSON('@Url.Action("GetCategoriesByLang", "Events")', { langId: langId }, function (data) {
                    var items = '<option value="">-- Select Category --</option>';
                    $.each(data, function (i, category) {
                        var selected = category.id == selectedCategoryId ? "selected" : "";
                        items += "<option value='" + category.id + "' " + selected + ">" + category.name + " (#" + category.id + ")</option>";
                    });
                    $('#categorySelect').html(items);
                });
            }

            $('#langSelect').change(function () {
                loadCategories($(this).val(), null);
            });

            // Initial load
            loadCategories($('#langSelect').val(), '@Model.CategoryId');
        });
    </script>
}
