@model VITBO.Services.UpdateEventRequest

@{
    ViewData["Title"] = "Edit Event";
    var heroImages = ViewBag.HeroImages as List<VITBO.Models.HeroImageDto> ?? new List<VITBO.Models.HeroImageDto>();
}

<div class="card border-0 shadow-sm border-start border-warning border-4">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-warning"><i class="bi bi-pencil-square me-2"></i> Edit Event #@Model.id</h5>
        <div class="btn-group">
            <button type="button" class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#galleryModal">
                <i class="bi bi-images me-1"></i> Gallery
            </button>
            <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#stageImagesModal" id="btnStageImages" style="display:none;">
                <i class="bi bi-map me-1"></i> Stage Images
            </button>
        </div>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-8 form-floating mb-3">
                    <input asp-for="Title" class="form-control" placeholder="Title" />
                    <label asp-for="Title" class="ms-2">Event Title</label>
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-4 form-floating mb-3">
                    <select asp-for="LangID" class="form-select" id="langSelect">
                        <option value="1">English (1)</option>
                        <option value="2">Italiano (2)</option>
                    </select>
                    <label asp-for="LangID" class="ms-2">Language</label>
                    <span asp-validation-for="LangID" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="EndDate" type="date" class="form-control" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
                    <label asp-for="EndDate" class="ms-2">End Date (Optional)</label>
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <select asp-for="HeroImage" class="form-select">
                        <option value="">-- No Hero Image --</option>
                        @foreach (var hero in heroImages)
                        {
                            <option value="@hero.ImageUrl">@hero.Name</option>
                        }
                    </select>
                    <label asp-for="HeroImage" class="ms-2">Hero Image</label>
                    <span asp-validation-for="HeroImage" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label d-block">Cover Image</label>
                    <div class="d-flex align-items-center gap-3">
                        @if (!string.IsNullOrEmpty(Model.CoverImage))
                        {
                            <img src="@Model.CoverImage" id="previewCover" class="img-thumbnail" style="height: 100px; width: 100px; object-fit: cover;" />
                        }
                        else
                        {
                            <div id="previewCover" class="bg-light border d-flex align-items-center justify-content-center" style="height: 100px; width: 100px;">
                                <i class="bi bi-image text-muted"></i>
                            </div>
                        }
                        <div class="flex-grow-1">
                            <input type="file" id="uploadCover" class="form-control" accept="image/*" />
                            <input type="hidden" asp-for="CoverImage" id="hiddenCoverImage" />
                            <div class="mt-1 small text-muted">Click to change cover. Will be converted to PNG.</div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="EventDate" type="date" class="form-control" value="@Model.EventDate.ToString("yyyy-MM-dd")" />
                    <label asp-for="EventDate" class="ms-2">Event Date</label>
                    <span asp-validation-for="EventDate" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" />
                    <label asp-for="Price" class="ms-2">Ticket Price (€)</label>
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="col-12 form-floating mb-3">
                    <input asp-for="Location" class="form-control" placeholder="Location" />
                    <label asp-for="Location" class="ms-2">Location / Venue</label>
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="col-12 form-floating mb-3">
                    <textarea asp-for="Description" class="form-control" placeholder="Description" style="height: 120px">@Model.Description</textarea>
                    <label asp-for="Description" class="ms-2">Event Description</label>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="form-check form-switch mt-2">
                        <input asp-for="IsOnline" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsOnline" class="form-check-label text-muted fw-bold">Online Event</label>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="form-check form-switch mt-2">
                        <input asp-for="HasVariantPrice" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="HasVariantPrice" class="form-check-label text-muted fw-bold">Has Variant Price</label>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="form-check form-switch mt-2">
                        <input asp-for="HasNeeds" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="HasNeeds" class="form-check-label text-muted fw-bold">Has Needs</label>
                    </div>
                </div>

                <div class="col-md-12 mb-3" id="programPdfSection" style="display:none;">
                    <label class="form-label">Program PDF</label>
                    <div class="input-group">
                        <input type="file" id="uploadPdf" class="form-control" accept="application/pdf" />
                        @if (!string.IsNullOrEmpty(Model.ProgramPdf))
                        {
                            <a href="@Model.ProgramPdf" target="_blank" class="btn btn-outline-secondary"><i class="bi bi-file-earmark-pdf"></i> View Current</a>
                        }
                    </div>
                    <input type="hidden" asp-for="ProgramPdf" id="hiddenProgramPdf" />
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <select asp-for="CategoryId" class="form-select" id="categorySelect">
                        <option value="">-- Select Category --</option>
                    </select>
                    <label asp-for="CategoryId" class="ms-2">Category (Optional)</label>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="col-12 mt-4 d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-warning text-dark px-5 fw-bold"><i class="bi bi-save me-2"></i> Update Event</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Gallery Modal -->
<div class="modal fade" id="galleryModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Event Gallery</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Upload New Photo</label>
                    <div class="input-group">
                        <input type="file" id="galleryUpload" class="form-control" accept="image/*" />
                        <input type="text" id="galleryCaption" class="form-control" placeholder="Caption (optional)" />
                        <button class="btn btn-warning" type="button" id="btnUploadGallery">Upload</button>
                    </div>
                </div>
                <hr />
                <div id="galleryContainer" class="row g-2">
                    <!-- Photos will be loaded here via AJAX -->
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            const apiBase = '@ViewBag.ApiBase'; // Ensure this is passed or use a fixed one
            const eventId = @Model.id;

            function loadCategories(langId, selectedCategoryId) {
                $.getJSON('@Url.Action("GetCategoriesByLang", "Events")', { langId: langId }, function (data) {
                    var items = '<option value="">-- Select Category --</option>';
                    $.each(data, function (i, category) {
                        var selected = category.id == selectedCategoryId ? "selected" : "";
                        items += "<option value='" + category.id + "' " + selected + ">" + category.name + " (#" + category.id + ")</option>";
                    });
                    $('#categorySelect').html(items).trigger('change');
                });
            }

            $('#categorySelect').change(function() {
                const catId = $(this).val();
                if (catId == 3 || catId == 4) {
                    $('#programPdfSection').show();
                    $('#btnStageImages').show();
                } else {
                    $('#programPdfSection').hide();
                    $('#btnStageImages').hide();
                }
            });

            $('#langSelect').change(function () {
                loadCategories($(this).val(), null);
            });

            // Initial load
            loadCategories($('#langSelect').val(), '@Model.CategoryId');

            // --- AJAX Uploads ---
            $('#uploadCover').change(async function() {
                const file = this.files[0];
                if (!file) return;

                const res = await performUpload(file, 'Events', 'EventCoverImage');
                if (res.success) {
                    $('#hiddenCoverImage').val(res.fileUrl);
                    $('#previewCover').attr('src', res.fileUrl).removeClass('bg-light');
                    alert('Cover updated!');
                } else {
                    alert('Upload failed: ' + res.message);
                }
            });

            $('#uploadPdf').change(async function() {
                const file = this.files[0];
                if (!file) return;

                const res = await performUpload(file, 'Events', 'EventProgramPdf');
                if (res.success) {
                    $('#hiddenProgramPdf').val(res.fileUrl);
                    alert('PDF updated!');
                } else {
                    alert('Upload failed: ' + res.message);
                }
            });

            async function performUpload(file, parentType, uploadType, extra = {}) {
                const formData = new FormData();
                formData.append('File', file);
                formData.append('ParentType', parentType);
                formData.append('ParentId', eventId);
                formData.append('UploadType', uploadType);
                formData.append('LangId', $('#langSelect').val());
                for (const key in extra) formData.append(key, extra[key]);

                // We'll use a simple proxy in the controller for this
                const response = await fetch('@Url.Action("AjaxUpload", "Events")', {
                    method: 'POST',
                    body: formData
                });
                return await response.json();
            }

            $('#btnUploadGallery').click(async function() {
                const file = $('#galleryUpload')[0].files[0];
                if (!file) { alert('Select a file'); return; }

                const res = await performUpload(file, 'Events', 'EventGalleryImage', {
                    Caption: $('#galleryCaption').val()
                });

                if (res.success) {
                    alert('Photo added!');
                    // reload gallery...
                } else {
                    alert(res.message);
                }
            });
        });
    </script>
}
