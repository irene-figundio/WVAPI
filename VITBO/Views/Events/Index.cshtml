@model List<VITBO.Models.EventDto>

@{
    ViewData["Title"] = "Events Management";
    int currentLangId = ViewData["CurrentLangId"] != null ? (int)ViewData["CurrentLangId"]! : 1;
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-warning"><i class="bi bi-calendar-event me-2"></i> Events Directory</h5>
        <a asp-action="Create" class="btn btn-warning btn-sm text-dark fw-bold"><i class="bi bi-plus-circle me-1"></i> Create Event</a>

        <form method="get" asp-action="Index" class="row g-2 align-items-center">
            <div class="col-auto d-flex align-items-center">
                <label class="me-2 text-muted small fw-bold">Language:</label>
                <select name="langId" class="form-select form-select-sm" onchange="this.form.submit()">
                    <!option value="1" @(currentLangId == 1 ? "selected" : "")>English (1)</!option>
                    <!option value="2" @(currentLangId == 2 ? "selected" : "")>Italian (2)</!option>
                </select>
            </div>
            <div class="col-auto">
                <div class="input-group input-group-sm">
                    <input type="text" name="search" class="form-control" placeholder="Search events..." value="@ViewData["SearchTerm"]">
                    <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="ps-4">ID</th>
                        <th scope="col">Event Details</th>
                        <th scope="col">Schedule</th>
                        <th scope="col">Location</th>
                        <th scope="col">Format</th>
                        <th scope="col" class="text-end pe-4">Price</th>
                        <th scope="col" class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var evt in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-bold">#@evt.Id</td>
                                <td>
                                    <span class="d-block fw-bold text-dark">@evt.Title</span>
                                    @if (!string.IsNullOrEmpty(evt.Subtitle))
                                    {
                                        <small class="text-muted d-block text-truncate" style="max-width: 200px;">@evt.Subtitle</small>
                                    }
                                </td>
                                <td>
                                    <div>
                                        <i class="bi bi-calendar-check me-1 text-primary"></i>
                                        @evt.EventDate.ToString("d")
                                    </div>
                                    @if (evt.StartTime.HasValue)
                                    {
                                        <small class="text-muted"><i class="bi bi-clock me-1"></i> @evt.StartTime.Value.ToString(@"hh\:mm")</small>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(evt.Location))
                                    {
                                        <div class="text-truncate" style="max-width: 200px;">
                                            <i class="bi bi-geo-alt text-danger me-1"></i> @evt.Location
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Not specified</span>
                                    }
                                </td>
                                <td>
                                    @if (evt.IsOnline)
                                    {
                                        <span class="badge bg-info text-dark"><i class="bi bi-globe me-1"></i>Online</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-building me-1"></i>In-Person</span>
                                    }
                                </td>
                                <td class="text-end pe-4 fw-bold">
                                    @(evt.Price > 0 ? "€ " + evt.Price.ToString("F2") : "Free")
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@evt.Id" class="btn btn-sm btn-outline-primary mb-1"><i class="bi bi-pencil"></i></a>
                                    <a asp-controller="Galleries" asp-action="Index" asp-route-eventId="@evt.Id" class="btn btn-sm btn-outline-info mb-1" title="Manage Galleries"><i class="bi bi-images"></i></a>
                                    <a asp-controller="EventExperts" asp-action="Index" asp-route-eventId="@evt.Id" class="btn btn-sm btn-outline-secondary mb-1" title="Manage Experts"><i class="bi bi-person-badge"></i></a>

                                    @if (evt.HasVariantPrice)
                                    {
                                        <a asp-action="VariantPrices" asp-route-eventId="@evt.Id" class="btn btn-sm btn-outline-success mb-1" title="Variant Prices"><i class="bi bi-currency-euro"></i> Prices</a>
                                    }
                                    @if (evt.HasNeeds)
                                    {
                                        <a asp-action="EventNeeds" asp-route-eventId="@evt.Id" class="btn btn-sm btn-outline-warning mb-1" title="Event Needs"><i class="bi bi-exclamation-triangle"></i> Needs</a>
                                    }

                                    <form asp-action="Delete" asp-route-id="@evt.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this event?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger mb-1"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">No events found for this language.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
