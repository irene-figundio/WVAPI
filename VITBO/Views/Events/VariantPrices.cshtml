@model List<VITBO.Models.VariantPriceDto>

@{
    ViewData["Title"] = "Variant Prices";
    int eventId = ViewBag.EventId;
}

<div class="row">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm border-start border-success border-4">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-success"><i class="bi bi-currency-euro me-2"></i> Variant Prices for Event #@eventId</h5>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Events</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="ps-4">ID</th>
                                <th scope="col">Price</th>
                                <th scope="col">Description</th>
                                <th scope="col" class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4 text-muted fw-bold">#@item.Id</td>
                                        <td>€ @item.Price.ToString("F2")</td>
                                        <td>@item.Description</td>
                                        <td class="text-end pe-4">
                                            <form asp-action="DeleteVariantPrice" asp-route-id="@item.Id" asp-route-eventId="@eventId" method="post" class="d-inline" onsubmit="return confirm('Delete this price variation?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">No variant prices found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="m-0 font-weight-bold text-success">Add Variant Price</h6>
            </div>
            <div class="card-body p-4">
                <form asp-action="AddVariantPrice" method="post">
                    <input type="hidden" name="EventId" value="@eventId" />

                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Price (€)</label>
                        <input name="Price" type="number" step="0.01" class="form-control" required placeholder="0.00" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Description</label>
                        <input name="Description" class="form-control" placeholder="e.g. Early Bird, VIP" />
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-success text-white">
                            <i class="bi bi-plus-circle me-1"></i> Add Variation
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
