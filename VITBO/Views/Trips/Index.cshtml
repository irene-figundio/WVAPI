@model List<VITBO.Models.TripDto>
@{
    ViewData["Title"] = "Gestione Viaggi";
}

<div class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <h2><i class="bi bi-airplane me-2"></i> @ViewData["Title"]</h2>

        <form method="get" asp-action="Index" class="row g-2 align-items-center mb-0">
            <input type="hidden" name="eventId" value="@ViewBag.EventId" />
            <div class="col-auto d-flex align-items-center">
                <label class="me-2 text-muted small fw-bold">Lingua:</label>
                <select name="langId" class="form-select form-select-sm" onchange="this.form.submit()">
                    <!option value="1" @(ViewData["CurrentLangId"]?.ToString() == "1" ? "selected" : "")>English (1)</!option>
                    <!option value="2" @(ViewData["CurrentLangId"]?.ToString() == "2" ? "selected" : "")>Italiano (2)</!option>
                </select>
            </div>
            <div class="col-auto">
                <div class="input-group input-group-sm">
                    <input type="text" name="search" class="form-control" placeholder="Cerca città/paese..." value="@ViewData["SearchTerm"]">
                    <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </div>
        </form>

        <a asp-action="Create" asp-route-eventId="@ViewBag.EventId" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Nuovo Viaggio
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Evento ID</th>
                            <th>Partenza</th>
                            <th>Arrivo</th>
                            <th>Durata</th>
                            <th>Max Ospiti</th>
                            <th>Status</th>
                            <th class="text-end">Azioni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">Nessun viaggio trovato.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.EventId</td>
                                    <td>@item.DepartureCity (@item.DepartureCountry)</td>
                                    <td>@item.ArrivalCity (@item.ArrivalCountry)</td>
                                    <td>@item.DurationDays gg / @item.DurationNights nn</td>
                                    <td>@item.MaxGuests</td>
                                    <td>
                                        <span class="badge @(item.Status switch {
                                            "done" => "bg-secondary",
                                            "cancelled" => "bg-danger",
                                            "booking" => "bg-info",
                                            "started" => "bg-primary",
                                            "in_progress" => "bg-success",
                                            _ => "bg-warning"
                                        })">@item.Status</span>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info text-white" title="Dettagli">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary" title="Modifica">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Sicuro di voler eliminare questo viaggio?');" class="d-inline">
                                                <button type="submit" class="btn btn-danger" title="Elimina">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
