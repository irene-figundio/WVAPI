@model List<VITBO.Models.TripDto>
@{
    ViewData["Title"] = "Gestione Viaggi";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-airplane me-2"></i> @ViewData["Title"]</h2>
        <a asp-action="Create" asp-route-eventId="@ViewBag.EventId" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Nuovo Viaggio
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Evento ID</th>
                            <th>Partenza</th>
                            <th>Arrivo</th>
                            <th>Durata</th>
                            <th>Max Ospiti</th>
                            <th>Status</th>
                            <th class="text-end">Azioni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">Nessun viaggio trovato.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.EventId</td>
                                    <td>@item.DepartureCity (@item.DepartureCountry)</td>
                                    <td>@item.ArrivalCity (@item.ArrivalCountry)</td>
                                    <td>@item.DurationDays gg / @item.DurationNights nn</td>
                                    <td>@item.MaxGuests</td>
                                    <td>
                                        <span class="badge @(item.Status switch {
                                            "done" => "bg-secondary",
                                            "cancelled" => "bg-danger",
                                            "booking" => "bg-info",
                                            "started" => "bg-primary",
                                            "in_progress" => "bg-success",
                                            _ => "bg-warning"
                                        })">@item.Status</span>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="Dettagli">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Modifica">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Sicuro di voler eliminare questo viaggio?');" style="display:inline;">
                                                <button type="submit" class="btn btn-outline-danger" title="Elimina">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
