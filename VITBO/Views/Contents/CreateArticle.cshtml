@model VITBO.Models.CreateContentRequest

@{
    ViewData["Title"] = "Create New Article";
}

<div class="card border-0 shadow-sm border-start border-danger border-4">
    <div class="card-header bg-white border-bottom py-3">
        <h5 class="mb-0 text-danger"><i class="bi bi-file-earmark-plus me-2"></i> Create New Article</h5>
    </div>
    <div class="card-body">
        <form asp-action="CreateArticle" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-8 form-floating mb-3">
                    <input asp-for="Title" class="form-control" placeholder="Article Title" />
                    <label asp-for="Title" class="ms-2">Article Title</label>
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-4 form-floating mb-3">
                    <select asp-for="LangID" class="form-select" id="langSelect">
                        <option value="1">English (1)</option>
                        <option value="2">Italiano (2)</option>
                    </select>
                    <label asp-for="LangID" class="ms-2">Language</label>
                    <span asp-validation-for="LangID" class="text-danger"></span>
                </div>

                <div class="col-md-12 form-floating mb-3">
                    <select asp-for="CategoryId" class="form-select" id="categorySelect">
                        <option value="">-- Select Category --</option>
                    </select>
                    <label asp-for="CategoryId" class="ms-2">Category</label>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="col-12 form-floating mb-3">
                    <textarea asp-for="Text" class="form-control" placeholder="Full article content" style="height: 250px"></textarea>
                    <label asp-for="Text" class="ms-2">Article Content</label>
                    <span asp-validation-for="Text" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="PublishDate" type="datetime-local" class="form-control" />
                    <label asp-for="PublishDate" class="ms-2">Publish Date & Time</label>
                    <span asp-validation-for="PublishDate" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="form-check form-switch mt-3 ms-2">
                        <input asp-for="IsPublished" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsPublished" class="form-check-label text-muted fw-bold">Publish Immediately</label>
                    </div>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="CoverImage" class="form-control" placeholder="Cover Image URL" />
                    <label asp-for="CoverImage" class="ms-2">Cover Image URL</label>
                    <span asp-validation-for="CoverImage" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="HeroImage" class="form-control" placeholder="Hero Image URL" />
                    <label asp-for="HeroImage" class="ms-2">Hero Image URL</label>
                    <span asp-validation-for="HeroImage" class="text-danger"></span>
                </div>

                <div class="col-12 mt-4 d-flex justify-content-between">
                    <a asp-action="Articles" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-danger px-5"><i class="bi bi-save me-2"></i> Create Article</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            function loadCategories(langId) {
                $.getJSON('@Url.Action("GetCategoriesByLang", "Contents")', { langId: langId }, function (data) {
                    var items = '<option value="">-- Select Category --</option>';
                    $.each(data, function (i, category) {
                        items += "<option value='" + category.id + "'>" + category.name + " (#" + category.id + ")</option>";
                    });
                    $('#categorySelect').html(items);
                });
            }

            $('#langSelect').change(function () {
                loadCategories($(this).val());
            });

            // Initial load
            loadCategories($('#langSelect').val());
        });
    </script>
}
