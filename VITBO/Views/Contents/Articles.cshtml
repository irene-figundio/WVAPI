@model List<VITBO.Models.ContentDto>

@{
    ViewData["Title"] = "Articles Management";
    int currentLangId = ViewData["CurrentLangId"] != null ? (int)ViewData["CurrentLangId"]! : 1;
}

<div class="card border-0 shadow-sm border-start border-danger border-4">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-danger"><i class="bi bi-file-earmark-text me-2"></i> Articles Directory</h5>

        <form method="get" asp-action="Articles" class="d-flex align-items-center">
            <label class="me-2 text-muted small fw-bold">Language ID:</label>
            <select name="langId" class="form-select form-select-sm" onchange="this.form.submit()">
                <!option value="1" @(currentLangId == 1 ? "selected" : "")>Italian (1)</!option>
                <!option value="2" @(currentLangId == 2 ? "selected" : "")>English (2)</!option>
                <!option value="3" @(currentLangId == 3 ? "selected" : "")>French (3)</!option>
                <!option value="4" @(currentLangId == 4 ? "selected" : "")>German (4)</!option>
            </select>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="ps-4" style="width: 5%">ID</th>
                        <th scope="col" style="width: 30%">Title</th>
                        <th scope="col" style="width: 35%">Preview</th>
                        <th scope="col" style="width: 10%">Status</th>
                        <th scope="col" class="text-end pe-4" style="width: 20%">Published</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var article in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-bold">#@article.Id</td>
                                <td>
                                    <span class="d-block fw-bold text-dark">@article.Title</span>
                                    @if (!string.IsNullOrEmpty(article.Subtitle))
                                    {
                                        <small class="text-muted d-block text-truncate">@article.Subtitle</small>
                                    }
                                </td>
                                <td>
                                    <span class="text-muted small text-truncate d-inline-block" style="max-width: 300px;">
                                        @(string.IsNullOrEmpty(article.Preview) ? "No preview available" : article.Preview)
                                    </span>
                                </td>
                                <td>
                                    @if (article.IsPublished)
                                    {
                                        <span class="badge bg-success">Published</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Draft</span>
                                    }
                                </td>
                                <td class="text-end pe-4 text-muted small">
                                    <i class="bi bi-clock me-1"></i> @article.PublishDate.ToString("g")
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No articles found for this language.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
