@model VITBO.Controllers.EditContentRequest

@{
    ViewData["Title"] = "Edit Content";
}

<div class="card border-0 shadow-sm border-start border-danger border-4">
    <div class="card-header bg-white border-bottom py-3">
        <h5 class="mb-0 text-danger"><i class="bi bi-pencil-square me-2"></i> Edit Content #@Model.Id</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ContentType" />

            <div class="row g-3">
                <div class="col-md-12 form-floating mb-3">
                    <input asp-for="Title" class="form-control" placeholder="Title" />
                    <label asp-for="Title" class="ms-2">Title</label>
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-12 form-floating mb-3">
                    <input asp-for="Subtitle" class="form-control" placeholder="Subtitle" />
                    <label asp-for="Subtitle" class="ms-2">Subtitle</label>
                    <span asp-validation-for="Subtitle" class="text-danger"></span>
                </div>

                <div class="col-12 form-floating mb-3">
                    <textarea asp-for="Text" class="form-control" placeholder="Full content" style="height: 250px"></textarea>
                    <label asp-for="Text" class="ms-2">Content Text</label>
                    <span asp-validation-for="Text" class="text-danger"></span>
                </div>

                <div class="col-12 form-floating mb-3">
                    <textarea asp-for="Preview" class="form-control" placeholder="Preview text" style="height: 100px"></textarea>
                    <label asp-for="Preview" class="ms-2">Preview Text</label>
                    <span asp-validation-for="Preview" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="CoverImage" class="form-control" placeholder="Cover Image URL" />
                    <label asp-for="CoverImage" class="ms-2">Cover Image URL</label>
                    <span asp-validation-for="CoverImage" class="text-danger"></span>
                </div>

                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="HeroImage" class="form-control" placeholder="Hero Image URL" />
                    <label asp-for="HeroImage" class="ms-2">Hero Image URL</label>
                    <span asp-validation-for="HeroImage" class="text-danger"></span>
                </div>

                <div class="col-md-4 form-floating mb-3">
                    <select asp-for="CategoryId" class="form-select">
                        <option value="">-- Select Category --</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var cat in (List<VITBO.Models.ContentCategoryDto>)ViewBag.Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>
                    <label asp-for="CategoryId" class="ms-2">Category</label>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                    <div class="form-text text-muted small mt-1">
                        <i class="bi bi-info-circle"></i> Select the primary grouping context for this content to help users find related items.
                    </div>
                </div>

                <div class="col-md-4 form-floating mb-3">
                    <input asp-for="PublishDate" type="datetime-local" class="form-control" />
                    <label asp-for="PublishDate" class="ms-2">Publish Date & Time</label>
                    <span asp-validation-for="PublishDate" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="form-check form-switch mt-3 ms-2">
                        <input asp-for="IsPublished" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsPublished" class="form-check-label text-muted fw-bold">Published</label>
                    </div>
                </div>

                <div class="col-12 mt-4 d-flex justify-content-between">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-danger px-5"><i class="bi bi-save me-2"></i> Update Content</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
