@model VITBO.Models.GalleryDto

@{
    ViewData["Title"] = "Create Gallery";
}

<div class="container-fluid px-4 py-4">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h2 class="h3 mb-0 text-gray-800">
                <i class="bi bi-images text-warning me-2"></i> @(Model.EventId > 0 ? $"Create Gallery for Event #{Model.EventId}" : "Create Gallery")
            </h2>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Back to Galleries
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="m-0 font-weight-bold text-warning">Gallery Details</h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        @if (Model.EventId > 0)
                        {
                            <input type="hidden" asp-for="EventId" />
                        }
                        else
                        {
                            <div class="mb-3">
                            <label asp-for="LangID" class="form-label fw-bold small text-muted">Language</label>
                            <select asp-for="LangID" class="form-select" id="langSelect">
                                <option value="1">English (1)</option>
                                <option value="2">Italiano (2)</option>
                            </select>
                            <span asp-validation-for="LangID" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EventId" class="form-label fw-bold small text-muted">Event</label>
                            <select asp-for="EventId" class="form-select" id="eventSelect">
                                <option value="">-- Select Event --</option>
                            </select>
                                <span asp-validation-for="EventId" class="text-danger small"></span>
                            </div>
                        }

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold small text-muted">Title</label>
                            <input asp-for="Title" class="form-control" placeholder="Enter gallery title..." />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-warning px-4">
                                <i class="bi bi-save me-1"></i> Create Gallery
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            function loadEvents(langId) {
                $.getJSON('@Url.Action("GetEventsByLang", "Events")', { langId: langId }, function (data) {
                    var items = '<option value="">-- Select Event --</option>';
                    $.each(data, function (i, ev) {
                        items += "<option value='" + ev.id + "'>" + ev.title + " (#" + ev.id + ")</option>";
                    });
                    $('#eventSelect').html(items);

                    @if(Model.EventId > 0) {
                        <text>$('#eventSelect').val(@Model.EventId);</text>
                    }
                });
            }

            $('#langSelect').change(function () {
                loadEvents($(this).val());
            });

            // Initial load
            loadEvents($('#langSelect').val());
        });
    </script>
}
