@model VITBO.Models.ContentImageDto

@{
    ViewData["Title"] = "Add Content Image";
}

<div class="container-fluid px-4 py-4">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h2 class="h3 mb-0 text-gray-800">
                <i class="bi bi-image text-info me-2"></i> @(Model.ContentId > 0 ? $"Add Image to Content #{Model.ContentId}" : "Add Content Image")
            </h2>
        </div>
        <div class="col-auto">
            <a asp-action="Index" asp-route-contentId="@(Model.ContentId > 0 ? Model.ContentId : (int?)null)" class="btn btn-outline-secondary btn-sm shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Back to Images
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="m-0 font-weight-bold text-info">Image Details</h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        @if (Model.ContentId > 0)
                        {
                            <input type="hidden" asp-for="ContentId" />
                        }
                        else
                        {
                            <div class="mb-3">
                                <label asp-for="ContentId" class="form-label fw-bold small text-muted">Content ID</label>
                                <input asp-for="ContentId" class="form-control" type="number" required />
                                <span asp-validation-for="ContentId" class="text-danger small"></span>
                            </div>
                        }
                        <input type="hidden" asp-for="LangID" />

                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">Upload Image</label>
                            <input type="file" id="fileUpload" class="form-control" accept="image/*" />
                            <input type="hidden" asp-for="ImageUrl" id="hiddenImageUrl" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                            <div id="uploadPreview" class="mt-2" style="display:none;">
                                <img src="" class="img-thumbnail" style="max-height: 200px;" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Caption" class="form-label fw-bold small text-muted">Caption (Optional)</label>
                            <input asp-for="Caption" class="form-control" id="caption" />
                            <span asp-validation-for="Caption" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Position" class="form-label fw-bold small text-muted">Position</label>
                            <input asp-for="Position" class="form-control" type="number" id="position" />
                            <span asp-validation-for="Position" class="text-danger small"></span>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" asp-route-contentId="@Model.ContentId" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-info text-white px-4" id="btnSubmit" disabled>
                                <i class="bi bi-save me-1"></i> Save Image
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#fileUpload').change(async function() {
                const file = this.files[0];
                if (!file) return;

                const formData = new FormData();
                formData.append('File', file);
                formData.append('ParentType', 'Content');
                formData.append('ParentId', '@Model.ContentId');
                formData.append('UploadType', 'ContentGalleryImage');
                formData.append('Caption', $('#caption').val());
                formData.append('LangId', '@Model.LangID');

                try {
                    const response = await fetch('@Url.Action("AjaxUpload", "ContentImages")', {
                        method: 'POST',
                        body: formData
                    });
                    const res = await response.json();
                    if (res.success) {
                        $('#hiddenImageUrl').val(res.fileUrl);
                        $('#uploadPreview img').attr('src', res.fileUrl);
                        $('#uploadPreview').show();
                        $('#btnSubmit').prop('disabled', false);
                        alert('Image uploaded successfully! Click Save to confirm.');
                    } else {
                        alert('Upload failed: ' + res.message);
                    }
                } catch (e) {
                    console.error(e);
                    alert('Error during upload');
                }
            });
        });
    </script>
}
